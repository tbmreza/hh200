#!/usr/bin/env bats

setup_file() {
  # Determine the Laravel app directory (either current dir or php-dev-server subdir)
  if [[ -f "artisan" ]]; then
    LARAVEL_DIR="$PWD"
  elif [[ -f "php-dev-server/artisan" ]]; then
    LARAVEL_DIR="$PWD/php-dev-server"
  else
    echo "Error: Cannot find Laravel app directory" >&2
    exit 1
  fi

  # Start Laravel dev server once for the whole suite
  (cd "$LARAVEL_DIR" && php artisan serve --host=127.0.0.1 --port=9999) &>/tmp/laravel-dev.log &
  export SERVER_PID=$!

  # Wait up to 10s for it to be ready
  for i in $(seq 1 20); do
    curl -sf http://127.0.0.1:9999 &>/dev/null && break
    sleep 0.5
  done
}

teardown_file() {
  kill "$SERVER_PID" 2>/dev/null || true
}

@test "can run our script" {
  hh200 /home/tbmreza/gh/hh200/examples/alpha.hhs
}
